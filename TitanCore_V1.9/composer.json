{
  "name": "modules/titancore",
  "type": "library",
  "description": "nWidart module TitanCore \u2014 Core AI infrastructure for the Titan Ecosystem",
  "version": "1.9.0",
  "autoload": {
    "psr-4": {
      "Modules\\TitanCore\\": "",
      "TitanSDK\\": "TitanSDK/src/"
    },
    "classmap": [
      "Database/Seeders"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Modules\\TitanCore\\Providers\\TitanCoreServiceProvider",
        "Modules\\TitanCore\\Providers\\TitanCorePlatformIntegrationServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "suggest": {
    "modules/aitools": "Required for Platform Manager integration (RegistryManager, ModuleManager)"
  }
}
